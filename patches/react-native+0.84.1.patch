     @try {
       [inv invokeWithTarget:strongModule];
     } @catch (NSException *exception) {
+      // ── DVNT diagnostic patch ────────────────────────────────────
+      // Log the throwing TurboModule + method + exception details
+      // BEFORE the C++ rethrow loses everything. Without this, the
+      // .ips crash log only shows the dispatch wrapper at this line
+      // and we can't tell WHICH native method threw. patched via
+      // patches/react-native+0.81.x.patch.
+      NSLog(@"╔═══════════════════════════════════════════════════════╗");
+      NSLog(@"║  [DVNT-TM-CRASH] TurboModule void method threw       ║");
+      NSLog(@"╚═══════════════════════════════════════════════════════╝");
+      NSLog(@"[DVNT-TM-CRASH] module:    %s", moduleName);
+      NSLog(@"[DVNT-TM-CRASH] method:    %s", methodName);
+      NSLog(@"[DVNT-TM-CRASH] exc.name:  %@", exception.name);
+      NSLog(@"[DVNT-TM-CRASH] exc.reason:%@", exception.reason ?: @"(none)");
+      NSLog(@"[DVNT-TM-CRASH] userInfo:  %@", exception.userInfo ?: @{});
+      NSLog(@"[DVNT-TM-CRASH] ── exception call stack ──");
+      NSArray<NSString *> *stack = exception.callStackSymbols ?: @[];
+      for (NSUInteger i = 0; i < stack.count; i++) {
+        NSLog(@"[DVNT-TM-CRASH]  %02lu  %@", (unsigned long)i, stack[i]);
+      }
+      NSLog(@"[DVNT-TM-CRASH] ════════════════════════════════════════════");
+      // Persist to disk so JS side can surface on next launch.
+      // Best-effort: never throw from inside the @catch.
+      @try {
+        NSDictionary *payload = @{
+          @"timestamp": @([[NSDate date] timeIntervalSince1970]),
+          @"module": @(moduleName),
+          @"method": @(methodName),
+          @"name": exception.name ?: @"(unknown)",
+          @"reason": exception.reason ?: @"(none)",
+          @"userInfo": [NSString stringWithFormat:@"%@", exception.userInfo ?: @{}],
+          @"callStackSymbols": stack,
+        };
+        NSError *jsonErr = nil;
+        NSData *data = [NSJSONSerialization
+            dataWithJSONObject:payload
+                       options:NSJSONWritingPrettyPrinted
+                         error:&jsonErr];
+        if (!jsonErr && data != nil) {
+          NSURL *docs = [[NSFileManager defaultManager] URLsForDirectory:NSDocumentDirectory inDomains:NSUserDomainMask].firstObject;
+          if (docs != nil) {
+            NSURL *fileURL = [docs URLByAppendingPathComponent:@"dvnt-turbomodule-crash.json"];
+            [data writeToURL:fileURL atomically:YES];
+          }
+        }
+      } @catch (NSException *innerExc) {
+        NSLog(@"[DVNT-TM-CRASH] persist failed: %@", innerExc.reason ?: @"(unknown)");
+      }
+      // Original behavior preserved — convert to JSError and throw so
+      // RN's existing JS-side error reporting still fires when reachable.
       throw convertNSExceptionToJSError(runtime, exception, std::string{moduleName}, methodNameStr);
     } @finally {
       [retainedObjectsForInvocation removeAllObjects];
